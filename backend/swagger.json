    "/simulations/{id}/start": {
      "post": {
        "operationId": "SimulationController_start",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Simulation UUID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimulationResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "simulations"
        ]
      }
    },
    "/simulations/{id}/finish": {
      "post": {
        "operationId": "SimulationController_finish",
        "parameters": [
          {
            "name": "id",
