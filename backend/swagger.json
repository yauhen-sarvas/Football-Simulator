                }
              }
            }
          }
        },
        "tags": [
          "simulations"
        ]
      }
    },
    "/simulations/{id}/restart": {
      "post": {
        "operationId": "SimulationController_restart",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Simulation UUID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
